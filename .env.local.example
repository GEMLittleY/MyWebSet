# Supabase 配置
# 在 Supabase Dashboard -> Settings -> API 中获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key（仅 seed/管理脚本使用，绝不要提交到 git）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# 管理员 GitHub 用户名（用于后台权限校验）
NEXT_PUBLIC_ADMIN_GITHUB_ID=GEMLittleY

# OpenAI（AI 教练用，缺失则 /api/coach/chat 返回 503）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# PostHog 产品分析（前端事件埋点）。缺失则所有 track() 调用静默 no-op。
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Stripe 订阅（Pro 主通道）
# 缺失时 /api/billing/* 返回 503，/pricing 退回 waitlist 模式。
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
# STRIPE_PORTAL_RETURN_URL=

# Paddle Billing webhook（PayPal / 支付宝等地区支付通道）。
# 仅 webhook 用，下单仍由 Paddle.js 在前端 Inline checkout 中完成。
PADDLE_NOTIFICATION_WEBHOOK_SECRET=
PADDLE_PRICE_PRO_MONTHLY=
PADDLE_PRICE_PRO_ANNUAL=
